<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record forcecreate="True" id="cron_hikvision_attendance_sync" model="ir.cron">
            <field name="name">Hikvision: Sync Attendance Records</field>
            <field name="model_id" ref="model_hikvision_device"/>
            <field name="state">code</field>
            <field name="code">model.search([('active', '=', True)]).sync_attendance()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
           
            <field name="priority">10</field>
        </record>

    </data>
</odoo>
