<?xml version="1.0"?>
<odoo>
<template id="report_payslip">
    <t t-call="web.external_layout">
         <div style="text-align:left; margin-bottom:10px;">
            <img t-if="o.company_id.logo"
                 t-att-src="image_data_uri(o.company_id.logo)"
                 style="max-height:200px;"/>
        </div>
        <div class="page">
           <h3 id="payslip_name" class="text-center">
                <span t-esc="'Salary Slip - ' + o.date_from.strftime('%B %Y')"/>
            </h3>
            <t t-set="is_invalid" t-value="o._is_invalid()"/>
            <div t-if="is_invalid">
                <strong id="invalid_warning"><span t-out="is_invalid">This payslip is not validated. This is not a legal document.</span></strong>
            </div>
            <div t-else="">
                <div class="oe_structure"></div>
            </div>
            <br></br>
            <br></br>
            <div id="infos_table">
                <table style="width:100%; border-collapse:collapse;">
                <thead>
                    <tr style="border-bottom:1px solid black;">
                        <th style="text-align:left; width:50%;"><strong>Employee Information</strong></th>
                        <th style="text-align:left; width:50%;"><strong>Other Information</strong></th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                <!-- LEFT SIDE -->
                <td style="vertical-align:top; padding-top:10px;">
                    <table style="width:100%;">
                        <tr>
                            <td><strong>Name:</strong></td>
                            <td><span t-field="o.employee_id.legal_name"/></td>
                        </tr>

                        <tr t-if="o.employee_id.identification_id">
                            <td><strong>Emirates ID:</strong></td>
                            <td><span t-field="o.employee_id.identification_id"/></td>
                        </tr>

                        <tr t-if="o.version_id.job_id">
                            <td><strong>Job Position:</strong></td>
                            <td><span t-field="o.version_id.job_id"/></td>
                        </tr>

                        <tr t-if="o.employee_id.contract_date_start">
                            <td><strong>DOJ:</strong></td>
                            <td><span t-field="o.employee_id.contract_date_start" t-options='{"format": "dd/MM/yyyy"}'/></td>
                        </tr>

                        <tr t-if="o.version_id.department_id">
                            <td><strong>Department:</strong></td>
                            <td><span t-field="o.version_id.department_id"/></td>
                        </tr>
                    </table>

                </td>

                <!-- RIGHT SIDE -->
                <td style="vertical-align:top; padding-top:10px;">

                    <div invisible="1">
                        <t t-if="o.version_id.contract_date_end and o.date_to &gt; o.version_id.contract_date_end"
                           t-set="end_date"
                           t-value="o.version_id.contract_date_end"/>
                        <t t-else=""
                           t-set="end_date"
                           t-value="o.date_to"/>
                        </div>
                            <table style="width:100%;">
                                <tr>
                                    <td><strong>Pay Period:</strong></td>
                                    <td>
                                        <span t-if="o.date_from &lt; o.version_id.contract_date_start"
                                              t-field="o.version_id.contract_date_start"
                                              t-options='{"format": "dd/MM/yyyy"}'/>
                                        <span t-else=""
                                              t-field="o.date_from"
                                              t-options='{"format": "dd/MM/yyyy"}'/>
                                        -
                                        <span t-esc="end_date.strftime('%d/%m/%Y')"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td><strong>Paid On:</strong></td>
                                    <td><span t-field="o.compute_date" t-options='{"format": "dd/MM/yyyy"}'/></td>
                                </tr>

                                <tr t-if="o.version_id.contract_type_id">
                                    <td><strong>Contract Type:</strong></td>
                                    <td><span t-field="o.version_id.contract_type_id"/></td>
                                </tr>

                                <tr>
                                    <td><strong>Working Days:</strong></td>
                                    <td>
<!--                                        <t t-if="o.version_id.resource_calendar_id.flexible_hours">-->
<!--                                            <span t-field="o.version_id.resource_calendar_id.full_time_required_hours"/> Hours / Week-->
<!--                                        </t>-->
<!--                                        <t t-else="">-->
<!--                                            <span t-field="o.version_id.hours_per_week"/> Hours / Week-->
<!--                                        </t>-->
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </tbody>

            </table>
            </div>
            <br></br>
            <br></br>
            <div id="payslip_lines_table">
                <table class="table table-sm table-borderless">
                    <thead class="o_black_border">
                        <tr>
                            <strong><th id="line_header_name">Name</th></strong>
                            <strong><th id="line_header_total" class="text-start">Total(AED)</th></strong>
                            <th id="line_header_ytd" class="text-start" t-if="o.ytd_computation">YTD</th>
                        </tr>
                    </thead>
                    <tbody id="payslip_lines">
                        <span t-foreach="o.line_ids.filtered(lambda line: line.appears_on_payslip)" t-as="line">
                            <t t-set="line_styling" t-value="line.get_payslip_styling_dict()"/>
                            <t t-set="line_style" t-value="line_styling['line_style']"/>
                            <t t-set="line_class" t-value="line_styling['line_class']"/>
                            <t t-set="o_title" t-value="line_styling['o_title']"/>
                            <tr id="line_display">
                                <td id="payslip_line_name" t-att-class="line_class" t-attf-style="#{line_style} #{'border-right: none;' if line.salary_rule_id.title else ''}" t-att-colspan="99 if line.salary_rule_id.title else 1">
                                    <span t-field="line.name" class="d-block"/>
                                    <span t-field="line.salary_rule_id.note" t-attf-class="#{line_class} d-inline-block text-truncate pb-0 mb-0 ps-1" style="max-width: 500px; font-size: 0.875em;"/>
                                </td>
                                <td id="payslip_line_total" t-attf-class="#{line_class} text-start #{o_title}" t-att-style="line_style">
                                    <span>
                                        <t t-esc="o.company_id.currency_id.name"/>
                                        <t t-esc="line.total"/>
                                    </span>
                                </td>
                                <td id="payslip_line_ytd" t-if="o.ytd_computation" t-attf-class="#{line_class} text-start #{o_title}" t-att-style="line_style">
                                    <span>
                                       <t t-esc="o.company_id.currency_id.name"/>
                                        <t t-esc="line.ytd"/>
                                    </span>

                                </td>
                            </tr>
                        </span>
                    </tbody>
                </table>
                <div class="oe_structure"></div>
              </div>
            <div id="to_pay">
                <t t-if="o.net_wage &gt;= 0">
                    <t t-set="allocations" t-value="o.compute_salary_allocations()"/>
                    <p t-foreach="allocations.items()" t-as="alloc">
                        <t t-set="bank" t-value="o.employee_id.bank_account_ids.filtered(lambda b: str(b.id) == alloc[0])[0]"/>
                        Paid to
                        <span class="fw-bold" t-esc="bank.acc_number or 'N/A'"/>
                        of <span class="fst-italic" t-field="bank.acc_holder_name"/>:

                        <span t-esc="alloc[1]" class="fw-bold" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                    </p>
                    <t t-if="not allocations">
                        <strong>Paid to</strong>
                        <span class="fst-italic" t-field="o.employee_id.legal_name"/>: <t t-esc="o.company_id.currency_id.name"/>
                        <span t-esc="o.net_wage" class="fw-bold"/>
                    </t>
                </t>
                <p t-if="o.net_wage &lt; 0">
                    The net amount will be recovered from the first positive remuneration established after this.
                </p>
            </div>
            <div style="margin-top:40px; border-top:1px solid black; padding-top:10px;">
                <p><strong>Transfer to :</strong> </p>
                <table style="width:100%; margin-top:30px;">
                    <tr>
                        <td>
                            <strong>Prepared By:</strong><br/>
                            Mulkiti Finance
                        </td>
                        <td style="text-align:center;">
                            <strong>Received By:</strong><br/>
                            Name<br/>
                            Sign<br/>
                            Date
                        </td>
                    </tr>
                </table>

            </div>

        </div>
    </t>
</template>

<template id="report_payslip_lang">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-set="o" t-value="o.with_context(lang=o.employee_id.lang or o.env.lang)"/>
            <t t-call="hr_payroll.report_payslip" t-lang="o.env.lang"/>
        </t>
    </t>
</template>
</odoo>
