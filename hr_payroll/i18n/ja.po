#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>categories</code>: dict containing the computed salary rule categories "
"(sum of amount of all rules belonging to that category)."
msgstr ""
"<code>カテゴリ</code>: 算出された給与ルールカテゴリを含む辞書(各カテゴリに属"
"するすべてのルールの金額の合計)。"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>employee</code>: hr.employee object"
msgstr "<code>employee</code>: hr.employee オブジェクト"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>inputs</code>: dict containing the computed inputs."
msgstr "<code>インプット</code>: 計算された入力値を含む辞書型です。"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>payslip</code>: hr.payslip object"
msgstr "<code>給与明細</code>: hr.payslip object"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result</code>: boolean True if the rule should be calculated, False "
"otherwise"
msgstr ""
"<code>result</code>：ブール値 — ルールを計算すべき場合は True、そうでない場合"
"は False"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>result</code>: float, base amount of the rule"
msgstr "<code>result</code>: float型、ルールの基本金額"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_name</code>: string, name of the line, which defaults to the "
"name field of the salary rule (useful if the name depends or should depend "
"on something computed in the rule)."
msgstr ""
"<code>result_name</code>: 行の名前。デフォルトは給与規則の名前フィールド(名前"
"が規則で計算されたものに依存する、または依存すべき場合に便利)。"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>result_qty</code>: float, quantity, which defaults to 1."
msgstr "<code>result_qty</code>: float型、数量、デフォルトは1。"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_rate</code>: float, rate between -100.0 and 100.0, which "
"defaults to 100.0 (%)."
msgstr ""
"<code>result_rate</code>: float型、-100.0〜100.0 の範囲の率（%）、デフォルト"
"は100。"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_rules</code>: dict containing the rules amounts, quantities, "
"rates and totals (previously computed)"
msgstr ""
"<code>result_rules</code>: あらかじめ計算されたルールの金額、数量、率、合計を"
"含む辞書型データ(dict)"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>total = result * result_rate / 100 * result_qty</code>"
msgstr "<code>合計 = result * result_rate / 100 * result_qty</code>"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>version</code>: hr.version object"
msgstr "<code>version</code>: hr.versionオブジェクト"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>worked_days</code>: dict containing the computed worked days"
msgstr "<code>worked_days</code>: 計算された勤務日数を含む 辞書型データ(dict)"

