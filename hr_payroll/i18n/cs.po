#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>categories</code>: dict containing the computed salary rule categories "
"(sum of amount of all rules belonging to that category)."
msgstr ""
"<code>kategorie</code>: slovník obsahující vypočítané kategorie pravidel pro "
"výpočet platu (součet částek všech pravidel patřících do dané kategorie)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>employee</code>: hr.employee object"
msgstr "<code>zaměstnanec</code>: hr.employee objekt"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>inputs</code>: dict containing the computed inputs."
msgstr "<code>vstupy</code>: slovník obsahující vypočítané vstupy."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>payslip</code>: hr.payslip object"
msgstr "<code>výplatní páska</code>: hr.payslip objekt"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result</code>: boolean True if the rule should be calculated, False "
"otherwise"
msgstr ""
"<code>výsledek</code>: boolean True, pokud má být pravidlo vypočítáno, False "
"v opačném případě"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>result</code>: float, base amount of the rule"
msgstr "<code>výsledek</code>: float, základní částka pravidla"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_name</code>: string, name of the line, which defaults to the "
"name field of the salary rule (useful if the name depends or should depend "
"on something computed in the rule)."
msgstr ""
"<code>result_name</code>: řetězec, název řádku, jehož výchozí hodnotou je "
"pole name platového pravidla (užitečné, pokud název závisí nebo by měl "
"záviset na něčem vypočítaném v pravidle)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>result_qty</code>: float, quantity, which defaults to 1."
msgstr "<code>result_qty</code>: float, množství, jehož výchozí hodnota je 1."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_rate</code>: float, rate between -100.0 and 100.0, which "
"defaults to 100.0 (%)."
msgstr ""
"<code>result_rate</code>: float, míra mezi -100,0 a 100,0, jejíž výchozí "
"hodnota je 100,0 (%)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_rules</code>: dict containing the rules amounts, quantities, "
"rates and totals (previously computed)"
msgstr ""
"<code>result_rules</code>: slovník obsahující pravidla částky, množství, "
"sazby a součty (předem vypočítané)"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>total = result * result_rate / 100 * result_qty</code>"
msgstr "<code>total = result * result_rate / 100 * result_qty</code>"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>version</code>: hr.version object"
msgstr "<code>verze</code>: objekt hr.version"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>worked_days</code>: dict containing the computed worked days"
msgstr "<code>pracovní_dny</code>: slovník obsahující vypočítané pracovní dny"

