#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>categories</code>: dict containing the computed salary rule categories "
"(sum of amount of all rules belonging to that category)."
msgstr ""
"<code>categories</code>: dict, joka sisältää lasketut palkkasääntökategoriat "
"(kaikkien kyseiseen kategoriaan kuuluvien sääntöjen summa)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>employee</code>: hr.employee object"
msgstr "<code>työntekijä</code>: hr.employee object"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>inputs</code>: dict containing the computed inputs."
msgstr "<code>inputs</code>: dict, joka sisältää lasketut syötteet."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>payslip</code>: hr.payslip object"
msgstr "<code>payslip</code>: hr.payslip object"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result</code>: boolean True if the rule should be calculated, False "
"otherwise"
msgstr ""
"<code>result</code>: boolean-arvo True, jos sääntö tulisi laskea, muuten "
"False"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>result</code>: float, base amount of the rule"
msgstr "<code>tulos</code>: float, säännön perusmäärä"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_name</code>: string, name of the line, which defaults to the "
"name field of the salary rule (useful if the name depends or should depend "
"on something computed in the rule)."
msgstr ""
"<code>result_name</code>: merkkijono, rivin nimi, jonka oletus on "
"palkkasäännön nimikenttä (hyödyllinen, jos nimi riippuu tai sen pitäisi "
"riippua säännössä lasketusta arvosta)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>result_qty</code>: float, quantity, which defaults to 1."
msgstr "<code>result_qty</code>: liukuluku, määrä, jonka oletus on 1."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_rate</code>: float, rate between -100.0 and 100.0, which "
"defaults to 100.0 (%)."
msgstr ""
"<code>result_rate</code>: liukuluku, arvo -100.0 ja 100.0 välillä, oletus "
"100.0 (%)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_rules</code>: dict containing the rules amounts, quantities, "
"rates and totals (previously computed)"
msgstr ""
"<code>result_rules</code>: säännöt sisältävä sanakirja määrillä, "
"prosenteilla ja summilla (aiemmin laskettu)"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>total = result * result_rate / 100 * result_qty</code>"
msgstr "<code>total = result * result_rate / 100 * result_qty</code>"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>version</code>: hr.version object"
msgstr "<code>versio</code>: hr.version object"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>worked_days</code>: dict containing the computed worked days"
msgstr "<code>worked_days</code>: lasketut työtunnit sisältävä sanakirja"

