#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>categories</code>: dict containing the computed salary rule categories "
"(sum of amount of all rules belonging to that category)."
msgstr ""
"<code>الفئات</code>: قاموس يحتوي على فئات قواعد الرواتب المحسوبة (مجموع قيمة "
"جميع القواعد التي تنتمي إلى تلك الفئة)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>employee</code>: hr.employee object"
msgstr "<code>الموظف</code>: hr.employee object"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>inputs</code>: dict containing the computed inputs."
msgstr "<code>المدخلات</code>: قاموس يحتوي على المدخلات المحسوبة."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>payslip</code>: hr.payslip object"
msgstr "<code>إيصال الدفع</code>: hr.payslip object"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result</code>: boolean True if the rule should be calculated, False "
"otherwise"
msgstr ""
"<code>النتيجة</code>: تكون القيمة المنطقية \"صحيحة\" إذا كان يجب حساب "
"القاعدة، و\"خاطئة\" في الحالات الأخرى"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>result</code>: float, base amount of the rule"
msgstr "<code>النتيجة</code>: رقم عشري، المبلغ الأساسي للقاعدة"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_name</code>: string, name of the line, which defaults to the "
"name field of the salary rule (useful if the name depends or should depend "
"on something computed in the rule)."
msgstr ""
"<code>result_name</code>: السلسلة أو اسم السطر، والذي يتم تعيينه افتراضيًا "
"كحقل الاسم في قاعدة الرواتب (يفيد ذلك إذا كان الاسم يعتمد أو يجب أن يعتمد "
"على شيء محسوب في القاعدة)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>result_qty</code>: float, quantity, which defaults to 1."
msgstr ""
"<code>result_qty</code>: float، الكمية، والتي تبلغ قيمتها الافتراضية 1."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_rate</code>: float, rate between -100.0 and 100.0, which "
"defaults to 100.0 (%)."
msgstr ""
"<code>result_rate</code>: float، معدل بين -100.0 و 100.0، والافتراضي هو "
"100.0 (%)."

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid ""
"<code>result_rules</code>: dict containing the rules amounts, quantities, "
"rates and totals (previously computed)"
msgstr ""
"<code>result_rules</code>: دليل يحتوي على القواعد والمبالغ والكميات "
"والمعدلات والإجماليات (المحسوبة مسبقًا)"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>total = result * result_rate / 100 * result_qty</code>"
msgstr "<code>total = result * result_rate / 100 * result_qty</code>"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>version</code>: hr.version object"
msgstr "<code>الإصدار</code>: hr.version object"

#. module: hr_payroll
#: model_terms:ir.ui.view,arch_db:hr_payroll.hr_salary_rule_form
msgid "<code>worked_days</code>: dict containing the computed worked days"
msgstr "<code>worked_days</code>: قائمة تحتوي على عدد أيام العمل المحسوبة"

